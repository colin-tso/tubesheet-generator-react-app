{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "shell: Push GH Page",
            "type": "shell",
            "command": "git subtree push --prefix build origin gh-pages",
            "problemMatcher": []
        },
        {
            "type": "npm",
            "script": "start",
            "label": "npm: start",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "isBackground": true, // This prevents the launch.json to wait for the completion of the task
            "problemMatcher": {
                "owner": "custom", // This is not needed but, required by the problemMatcher Object
                "pattern": {
                    "regexp": "^$" // This is not needed but, required by the problemMatcher Object
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE v[\\d.]+", // printed once when the dev server boots
                    "endsPattern": "ready in \\d+ ?ms" // signals the server is up and listening
                }
            }
        },
        {
            "type": "npm",
            "script": "build",
            "label": "npm: build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$tsc"] // tsc -b runs first; surface its errors in the Problems panel
        },
        {
            "type": "npm",
            "script": "test",
            "label": "npm: test",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "RUN\\s+v[\\d.]+", // a new test run starting (initial run or on file change)
                    "endsPattern": "Waiting for file changes" // vitest watch mode idle state
                }
            }
        }
    ]
}
